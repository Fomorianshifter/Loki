# Where the Loki checkout lives on this Pi.
LOKI_HOME=/home/pi/Loki

# Full path to the Loki executable to start.
LOKI_BIN=/home/pi/Loki/build/release/loki_app

# The systemd service name that helper commands manage.
LOKI_SERVICE_NAME=loki.service

# Use "system" for the machine-wide service installed by the Pi setup scripts.
LOKI_SYSTEMD_SCOPE=system

# Seconds to allow the first-run smoke test before treating startup as healthy.
LOKI_FIRST_RUN_TIMEOUT=10

# Safe mode should stay on for normal installs.
SAFE_MODE=1

# Credit writing/changing is intentionally OFF by default.
# Only set this to 1 if you have also set SAFE_MODE=0 on purpose.
ENABLE_CREDIT_WRITE=0
