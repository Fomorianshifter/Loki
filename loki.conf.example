# Loki master runtime config example
# Copy to /etc/loki/loki.conf or set LOKI_CONFIG_PATH to a custom path.

[device]
name=Loki
species=dragon
stage=egg
theme=default
board_profile=raspberry_pi_zero_w
first_boot=true

[personality]
mood_enabled=true
base_mood=curious
mood_decay_rate=5
friendliness=80
mischief=40
energy=70

[ui]
brightness=80
rotation=0
show_stats=true
show_face=true
idle_animation=breathe

[behavior]
auto_evolve=true
evolution_speed=normal
sleep_enabled=true
sound_enabled=false
interaction_timeout_sec=60

[credits]
credits_enabled=true
starting_balance=100
allow_write=true
allow_spend=true

[logging]
level=info
error_logging=true

[hardware_overrides]
spi_freq_tft=32000000
spi_freq_flash=20000000
i2c_freq=100000
uart_baud=115200

[paths]
data_dir=/var/lib/loki
log_dir=/var/log/loki
